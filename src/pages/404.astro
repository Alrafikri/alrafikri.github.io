---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Almas Rausan Fikri"
  description="The page you're looking for doesn't exist."
>
  <section class="hero">
    <div class="container">
      <h1>404</h1>
      <p class="bio" style="margin-top: 16px;">
        Page not found. The link might be broken, or the page may have been moved.
      </p>
      <div class="badge-row">
        <a href="/" class="badge">&larr; Back to home</a>
      </div>
    </div>
  </section>
</BaseLayout>

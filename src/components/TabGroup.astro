---
export interface Props {
  tabs: string[];
}

const { tabs } = Astro.props;
const count = Math.min(tabs.length, 10);
---

<div class="tab-group">
  <div class="tab-bar" role="tablist">
    {tabs.map((label, i) => (
      <button
        type="button"
        class="tab-btn"
        class:list={{ 'tab-active': i === 0 }}
        role="tab"
        aria-selected={i === 0}
        aria-controls={`tab-panel-${i}`}
        data-index={i}
      >{label}</button>
    ))}
  </div>
  <div class="tab-panels">
    <div class="tab-panel" class:list={{ 'tab-panel-active': count > 0 }} id="tab-panel-0" role="tabpanel" data-index="0">
      <slot name="panel-0" />
    </div>
    {count > 1 && (
      <div class="tab-panel" id="tab-panel-1" role="tabpanel" data-index="1">
        <slot name="panel-1" />
      </div>
    )}
    {count > 2 && (
      <div class="tab-panel" id="tab-panel-2" role="tabpanel" data-index="2">
        <slot name="panel-2" />
      </div>
    )}
    {count > 3 && (
      <div class="tab-panel" id="tab-panel-3" role="tabpanel" data-index="3">
        <slot name="panel-3" />
      </div>
    )}
    {count > 4 && (
      <div class="tab-panel" id="tab-panel-4" role="tabpanel" data-index="4">
        <slot name="panel-4" />
      </div>
    )}
    {count > 5 && (
      <div class="tab-panel" id="tab-panel-5" role="tabpanel" data-index="5">
        <slot name="panel-5" />
      </div>
    )}
    {count > 6 && (
      <div class="tab-panel" id="tab-panel-6" role="tabpanel" data-index="6">
        <slot name="panel-6" />
      </div>
    )}
    {count > 7 && (
      <div class="tab-panel" id="tab-panel-7" role="tabpanel" data-index="7">
        <slot name="panel-7" />
      </div>
    )}
    {count > 8 && (
      <div class="tab-panel" id="tab-panel-8" role="tabpanel" data-index="8">
        <slot name="panel-8" />
      </div>
    )}
    {count > 9 && (
      <div class="tab-panel" id="tab-panel-9" role="tabpanel" data-index="9">
        <slot name="panel-9" />
      </div>
    )}
  </div>
</div>

<script>
  (() => {
    class TabGroup {
      constructor(el) {
        this.el = el;
        this.buttons = el.querySelectorAll('.tab-btn');
        this.panels = el.querySelectorAll('.tab-panel');
        this.active = 0;
        this.touchStartX = 0;
        this.touchEndX = 0;

        this.el.classList.add('is-ready');

        this.buttons.forEach((btn) => {
          btn.addEventListener('click', () => this.switchTo(parseInt(btn.dataset.index)));
        });

        el.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        el.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        }, { passive: true });
      }

      switchTo(index) {
        if (index === this.active) return;
        const direction = index > this.active ? 'left' : 'right';

        this.panels[this.active].classList.remove('tab-panel-active', 'tab-slide-left', 'tab-slide-right');
        this.buttons[this.active].classList.remove('tab-active');
        this.buttons[this.active].setAttribute('aria-selected', 'false');

        const incoming = this.panels[index];
        incoming.classList.add('tab-panel-active');
        incoming.classList.add(direction === 'left' ? 'tab-slide-right' : 'tab-slide-left');

        this.buttons[index].classList.add('tab-active');
        this.buttons[index].setAttribute('aria-selected', 'true');
        this.active = index;
      }

      handleSwipe() {
        const diff = this.touchStartX - this.touchEndX;
        if (Math.abs(diff) < 50) return;
        if (diff > 0 && this.active < this.panels.length - 1) {
          this.switchTo(this.active + 1);
        } else if (diff < 0 && this.active > 0) {
          this.switchTo(this.active - 1);
        }
      }
    }

    document.querySelectorAll('.tab-group').forEach((el) => new TabGroup(el));
  })();
</script>

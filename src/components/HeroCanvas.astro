<div id="hero-canvas-wrap" aria-hidden="true">
  <canvas id="hero-canvas"></canvas>
</div>

<style>
  #hero-canvas-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
(function() {
  if (!('matchMedia' in globalThis) || !matchMedia('(min-width: 768px)').matches) return;

  const canvas = document.getElementById('hero-canvas');
  const wrap = document.getElementById('hero-canvas-wrap');
  if (!canvas || !wrap) return;

  const ctx = canvas.getContext('2d');
  let w, h;

  function resize() {
    w = wrap.offsetWidth || window.innerWidth;
    h = wrap.offsetHeight || 600;
    canvas.width = w;
    canvas.height = h;
  }
  resize();
  window.addEventListener('resize', resize);

  // ── Cherry blossom petals ──
  const PETAL_COUNT = 40;
  const petals = [];

  for (let i = 0; i < PETAL_COUNT; i++) {
    petals.push({
      x: Math.random() * w,
      y: Math.random() * h,
      size: 6 + Math.random() * 10,
      speedY: 0.3 + Math.random() * 0.5,
      speedX: 0.2 + Math.random() * 0.4,
      rot: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.03,
      sway: Math.random() * 2,
      swaySpeed: 0.01 + Math.random() * 0.02,
      opacity: 0.3 + Math.random() * 0.3,
    });
  }

  function drawPetal(p) {
    ctx.save();
    ctx.translate(p.x + Math.sin(Date.now() * p.swaySpeed) * p.sway, p.y);
    ctx.rotate(p.rot);
    ctx.globalAlpha = p.opacity;
    ctx.fillStyle = '#e8a0b4';

    // Petal shape: simple ellipse with pointed tip
    ctx.beginPath();
    ctx.ellipse(0, 0, p.size * 0.5, p.size * 0.3, 0, 0, Math.PI * 2);
    // Add a slight point at one end
    ctx.moveTo(-p.size * 0.15, 0);
    ctx.quadraticCurveTo(-p.size * 0.6, -p.size * 0.1, -p.size * 0.5, 0);
    ctx.quadraticCurveTo(-p.size * 0.6, p.size * 0.1, -p.size * 0.15, 0);
    ctx.fill();

    ctx.restore();
  }

  // ── Fireflies ──
  const FIREFLY_COUNT = 12;
  const fireflies = [];

  for (let i = 0; i < FIREFLY_COUNT; i++) {
    fireflies.push({
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * 0.2,
      vy: (Math.random() - 0.5) * 0.2,
      size: 1 + Math.random() * 2,
      phase: Math.random() * Math.PI * 2,
      speed: 0.01 + Math.random() * 0.02,
    });
  }

  function drawFirefly(f) {
    const glow = 0.3 + 0.7 * (0.5 + 0.5 * Math.sin(Date.now() * f.speed + f.phase));
    ctx.globalAlpha = glow * 0.5;

    // Glow halo
    const gradient = ctx.createRadialGradient(f.x, f.y, 0, f.x, f.y, f.size * 8);
    gradient.addColorStop(0, 'rgba(232, 160, 180, 0.3)');
    gradient.addColorStop(1, 'rgba(232, 160, 180, 0)');
    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.arc(f.x, f.y, f.size * 8, 0, Math.PI * 2);
    ctx.fill();

    // Core dot
    ctx.globalAlpha = glow * 0.6;
    ctx.fillStyle = '#f5f0e8';
    ctx.beginPath();
    ctx.arc(f.x, f.y, f.size, 0, Math.PI * 2);
    ctx.fill();
  }

  // ── Mist layers ──
  function drawMist() {
    const time = Date.now() * 0.0001;

    for (let i = 0; i < 3; i++) {
      const yBase = h - 40 - i * 30;
      const hue = 200 + i * 20;
      ctx.globalAlpha = 0.04 - i * 0.01;
      ctx.fillStyle = `hsl(${hue}, 20%, 40%)`;
      ctx.beginPath();
      ctx.moveTo(0, yBase + 20);

      for (let x = 0; x <= w; x += 10) {
        const wave = Math.sin(x * 0.01 + time + i * 2) * 8 +
                     Math.sin(x * 0.02 + time * 1.5 + i) * 4;
        ctx.lineTo(x, yBase + wave);
      }

      ctx.lineTo(w, h);
      ctx.lineTo(0, h);
      ctx.closePath();
      ctx.fill();
    }
  }

  // ── Background gradient ──
  function drawBackground() {
    const gradient = ctx.createLinearGradient(0, 0, 0, h);
    gradient.addColorStop(0, '#0f0e17');
    gradient.addColorStop(0.4, '#131127');
    gradient.addColorStop(0.7, '#151230');
    gradient.addColorStop(1, '#0f0e17');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, w, h);
  }

  // ── Stars ──
  const stars = [];
  for (let i = 0; i < 60; i++) {
    stars.push({
      x: Math.random() * w,
      y: Math.random() * h * 0.5,
      size: 0.5 + Math.random() * 1.5,
      twinkle: Math.random() * Math.PI * 2,
    });
  }

  function drawStars() {
    for (const s of stars) {
      const alpha = 0.2 + 0.3 * (0.5 + 0.5 * Math.sin(Date.now() * 0.002 + s.twinkle));
      ctx.globalAlpha = alpha;
      ctx.fillStyle = '#f5f0e8';
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // ── Shooting star ──
  let shootingStar = null;

  function spawnShootingStar() {
    shootingStar = {
      x: Math.random() * w * 0.8 + w * 0.1,
      y: Math.random() * h * 0.15,
      vx: 3 + Math.random() * 4,
      vy: 2 + Math.random() * 3,
      life: 1,
      tail: 30 + Math.random() * 20,
    };
  }

  function drawShootingStar() {
    if (!shootingStar) return;

    shootingStar.x += shootingStar.vx;
    shootingStar.y += shootingStar.vy;
    shootingStar.life -= 0.012;

    if (shootingStar.life <= 0) {
      shootingStar = null;
      return;
    }

    ctx.globalAlpha = shootingStar.life * 0.6;
    ctx.strokeStyle = '#f5f0e8';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(shootingStar.x, shootingStar.y);
    ctx.lineTo(
      shootingStar.x - shootingStar.vx * shootingStar.tail * 0.3,
      shootingStar.y - shootingStar.vy * shootingStar.tail * 0.3
    );
    ctx.stroke();

    // Head glow
    ctx.globalAlpha = shootingStar.life * 0.8;
    ctx.fillStyle = '#f5f0e8';
    ctx.beginPath();
    ctx.arc(shootingStar.x, shootingStar.y, 2, 0, Math.PI * 2);
    ctx.fill();
  }

  // Spawn shooting stars periodically
  let shootingStarTimer = 0;

  // ── Animation loop ──
  function animate() {
    ctx.clearRect(0, 0, w, h);

    drawBackground();
    drawMist();
    drawStars();

    // Update and draw petals
    for (const p of petals) {
      p.y += p.speedY;
      p.x += Math.sin(Date.now() * p.swaySpeed) * p.sway * 0.02 + p.speedX * 0.1;
      p.rot += p.rotSpeed;

      // Wrap around
      if (p.y > h + 20) {
        p.y = -20;
        p.x = Math.random() * w;
      }
      if (p.x > w + 30) p.x = -30;
      if (p.x < -30) p.x = w + 30;

      drawPetal(p);
    }

    // Update and draw fireflies
    for (const f of fireflies) {
      f.x += f.vx;
      f.y += f.vy;

      if (f.x > w + 10) f.x = -10;
      if (f.x < -10) f.x = w + 10;
      if (f.y > h + 10) f.y = -10;
      if (f.y < -10) f.y = h + 10;

      drawFirefly(f);
    }

    // Shooting stars
    shootingStarTimer++;
    if (shootingStarTimer > 300 + Math.random() * 200) {
      if (!shootingStar) {
        spawnShootingStar();
      }
      shootingStarTimer = 0;
    }
    drawShootingStar();

    ctx.globalAlpha = 1;
    requestAnimationFrame(animate);
  }

  animate();
})();
</script>

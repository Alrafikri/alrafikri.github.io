<div class="deer-mascot" aria-hidden="true">
  <div class="deer-speech" id="deer-speech">
    <span class="deer-speech-text" id="deer-speech-text">データ…めんどくさい…</span>
  </div>
  <div class="deer-body">
    <img src="/images/deer.svg" alt="" class="deer-img" width="120" height="144" />
  </div>
</div>

<style>
  .deer-mascot {
    position: absolute;
    right: 5%;
    bottom: 10%;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .deer-body {
    animation: deerFloat 4s ease-in-out infinite;
  }

  .deer-img {
    width: 120px;
    height: auto;
    display: block;
  }

  .deer-speech {
    background: #1a1a2e;
    border: 1px solid #2a2a3e;
    border-radius: 12px;
    padding: 10px 16px;
    margin-bottom: 10px;
    position: relative;
    max-width: 220px;
    animation: speechFade 8s ease-in-out infinite;
  }

  .deer-speech::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 6px solid #2a2a3e;
  }

  .deer-speech-text {
    font-family: 'Noto Serif JP', serif;
    font-size: 13px;
    color: #c4b5a0;
    line-height: 1.4;
    text-align: center;
    display: block;
  }

  @keyframes deerFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes speechFade {
    0%, 20% { opacity: 1; }
    30%, 90% { opacity: 0; }
    95%, 100% { opacity: 1; }
  }

  @media (max-width: 768px) {
    .deer-mascot {
      position: relative;
      right: auto;
      bottom: auto;
      margin-top: 20px;
    }

    .deer-img {
      width: 80px;
    }

    .deer-speech {
      max-width: 180px;
    }
  }
</style>

<script>
(function() {
  const textEl = document.getElementById('deer-speech-text');
  if (!textEl) return;

  const lines = [
    'データ…めんどくさい…',
    'I solve puzzles. Just… let me do it my way.',
  ];

  let index = 0;

  setInterval(() => {
    index = (index + 1) % lines.length;
    textEl.textContent = lines[index];
  }, 8000);
})();
</script>

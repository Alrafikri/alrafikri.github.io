<canvas id="hero-network" aria-hidden="true" tabindex="-1"></canvas>

<script>
import * as THREE from 'three';

document.addEventListener('DOMContentLoaded', function() {
const canvas = document.getElementById('hero-network');
if (!canvas) return;
if (!('matchMedia' in globalThis) || !matchMedia('(min-width: 768px)').matches) return;

const hero = canvas.closest('.hero');
if (!hero) return;

hero.style.position = 'relative';
canvas.style.cssText =
  'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;display:block';

const container = hero.querySelector('.container');
if (container) {
  container.style.position = 'relative';
  container.style.zIndex = '1';
}

const w = hero.offsetWidth;
const h = hero.offsetHeight;
canvas.width = w;
canvas.height = h;

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(60, w / h, 0.1, 1000);
camera.position.z = 12;

const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
renderer.setSize(w, h);
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

const NODE_COUNT = 70;
const positions = new Float32Array(NODE_COUNT * 3);
const velocities = [];

for (let i = 0; i < NODE_COUNT; i++) {
  const i3 = i * 3;
  positions[i3]     = (Math.random() - 0.5) * 14;
  positions[i3 + 1] = (Math.random() - 0.5) * 8;
  positions[i3 + 2] = (Math.random() - 0.5) * 6;
  velocities.push({
    x: (Math.random() - 0.5) * 0.005,
    y: (Math.random() - 0.5) * 0.005,
    z: (Math.random() - 0.5) * 0.005,
  });
}

const nodeGeo = new THREE.BufferGeometry();
nodeGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
const nodeMat = new THREE.PointsMaterial({
  color: 0x06b6d4,
  size: 0.45,
  transparent: true,
  opacity: 1.0,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
});
const points = new THREE.Points(nodeGeo, nodeMat);
scene.add(points);

const MAX_DIST = 4.5;
const lineMat = new THREE.LineBasicMaterial({
  color: 0x06b6d4,
  transparent: true,
  opacity: 0.4,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
});

let mouseX = 0;
let mouseY = 0;
document.addEventListener('mousemove', (e) => {
  const rect = hero.getBoundingClientRect();
  mouseX = ((e.clientX - rect.left) / rect.width) * 2 - 1;
  mouseY = -((e.clientY - rect.top) / rect.height) * 2 + 1;
});

const ro = new ResizeObserver(() => {
  const nw = hero.offsetWidth;
  const nh = hero.offsetHeight;
  canvas.width = nw;
  canvas.height = nh;
  camera.aspect = nw / nh;
  camera.updateProjectionMatrix();
  renderer.setSize(nw, nh);
});
ro.observe(hero);

let lines = null;

function animate() {
  requestAnimationFrame(animate);

  const pos = points.geometry.attributes.position.array;

  for (let i = 0; i < NODE_COUNT; i++) {
    const i3 = i * 3;
    pos[i3]     += velocities[i].x;
    pos[i3 + 1] += velocities[i].y;
    pos[i3 + 2] += velocities[i].z;

    if (pos[i3] > 7) velocities[i].x = -Math.abs(velocities[i].x);
    if (pos[i3] < -7) velocities[i].x = Math.abs(velocities[i].x);
    if (pos[i3 + 1] > 4) velocities[i].y = -Math.abs(velocities[i].y);
    if (pos[i3 + 1] < -4) velocities[i].y = Math.abs(velocities[i].y);
    if (pos[i3 + 2] > 3) velocities[i].z = -Math.abs(velocities[i].z);
    if (pos[i3 + 2] < -3) velocities[i].z = Math.abs(velocities[i].z);
  }
  points.geometry.attributes.position.needsUpdate = true;

  const lineVerts = [];
  for (let i = 0; i < NODE_COUNT; i++) {
    const i3 = i * 3;
    for (let j = i + 1; j < NODE_COUNT; j++) {
      const j3 = j * 3;
      const dx = pos[i3] - pos[j3];
      const dy = pos[i3 + 1] - pos[j3 + 1];
      const dz = pos[i3 + 2] - pos[j3 + 2];
      const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);
      if (dist < MAX_DIST) {
        lineVerts.push(pos[i3], pos[i3 + 1], pos[i3 + 2]);
        lineVerts.push(pos[j3], pos[j3 + 1], pos[j3 + 2]);
      }
    }
  }

  if (lines) {
    scene.remove(lines);
    lines.geometry.dispose();
    lines = null;
  }
  if (lineVerts.length > 0) {
    const lineGeo = new THREE.BufferGeometry();
    lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(lineVerts, 3));
    lines = new THREE.LineSegments(lineGeo, lineMat);
    scene.add(lines);
  }

  points.rotation.x += (mouseY * 0.3 - points.rotation.x) * 0.02;
  points.rotation.y += (mouseX * 0.3 - points.rotation.y) * 0.02;

  renderer.render(scene, camera);
}

animate();
});
</script>

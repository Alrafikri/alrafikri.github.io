---
export interface Props {
  role: string;
  company: string;
  location: string;
  period: string;
  type: string;
  description: string[];
  tags?: string[];
}

const { role, company, location, period, type, description, tags = [] } = Astro.props;
---

<div class="experience-card">
  <div class="exp-header">
    <div class="exp-left">
      <h3>{role}</h3>
      <div class="exp-meta">
        <span class="exp-company">{company}</span>
        <span class="exp-sep">·</span>
        <span class="exp-location">{location}</span>
      </div>
    </div>
    <div class="exp-right">
      <span class="exp-period">{period}</span>
      <span class="exp-type">{type}</span>
    </div>
  </div>
  <ul class="exp-description">
    {description.map(item => <li>{item}</li>)}
  </ul>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</div>
